                <mxCell id="cw1" value="os.environ[&#39;CUDA_VISIBLE_DEVICES&#39;] = cuda_device&#xa;os.environ[&#39;FASTVIDEO_ATTENTION_BACKEND&#39;] = &#39;FLASH_ATTN&#39;&#xa;&#xa;must be set BEFORE importing torch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;fontFamily=monospace;" parent="1" vertex="1">
