                </mxCell>
                <mxCell id="cp1" value="mp.get_context(&#39;spawn&#39;)&#xa;cmd_q, resp_q = ctx.Queue(), ctx.Queue()&#xa;(optional) shared_stream_buffer = mp.RawArray(&#39;B&#39;, 256 MiB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ef6c00;fontSize=10;align=left;spacingLeft=8;fontFamily=monospace;" parent="1" vertex="1">
